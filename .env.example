# =============================================================================
# ChildCheck — .env.example
#
# Copy this file to `.env` and edit it before the first `docker compose up -d`
# (Docker) or before running the install script (native).
# =============================================================================

# --- Required -----------------------------------------------------------------

# The public URL users browse to (no trailing slash). Used by NextAuth for
# cookie scope + by the app to know its own origin.
NEXTAUTH_URL=http://localhost:3000

# 32-byte hex secret used to sign session JWTs. Generate with:
#   openssl rand -hex 32
NEXTAUTH_SECRET=

# --- Strongly recommended -----------------------------------------------------

# 32-byte hex AES-256-GCM key used to encrypt photos at rest + to seal backup
# bundles + to encrypt the stored SMTP password. Generate with:
#   openssl rand -hex 32
# WARNING: losing this key means existing photos + encrypted backups + the
# stored SMTP password cannot be decrypted.
CHILDCHECK_DATA_KEY=

# --- Optional (with defaults) -------------------------------------------------

# Next.js HTTP port (default 3000). If you change it, also update the ports:
# mapping in docker-compose.yml (Docker) or the systemd unit (native).
PORT=3000

# Socket.io port for the realtime mini-service (default 3003).
REALTIME_PORT=3003

# Bind address. Use 127.0.0.1 to restrict to localhost (e.g. behind a proxy).
HOSTNAME=0.0.0.0

# SQLite connection string. The `file:` prefix is required.
DATABASE_URL=file:./db/custom.db

# Where photos / branding / backups live. Override to mount a separate volume.
CHILDCHECK_DATA_DIR=./data

# Where the runtime persists auto-generated secrets.
CHILDCHECK_CONFIG_DIR=./config

# Shared secret for the realtime mini-service's internal /broadcast endpoint.
REALTIME_INTERNAL_KEY=

# --- Update checker (opt-in) --------------------------------------------------
#
# Set to the GitHub repo slug of the public ChildCheck repo to enable the
# read-only in-app update checker (shown on /admin → Updates card). Leave
# unset to disable update checking.
#
# Example:
#   CHILDCHECK_UPDATE_REPO=childcheck/childcheck
CHILDCHECK_UPDATE_REPO=

# --- SMTP (outbound email — env-var path) -------------------------------------
#
# When set, these take precedence over the SMTP config saved via /admin/settings
# → Email tab. The admin UI shows an "SMTP env vars are set" banner so the
# admin knows their saved config is being overridden.
#
# For Gmail, SMTP_PASS MUST be an App Password (not the account password).
# See docs/deployment/configuration.md → "Gmail App Password requirement".
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURITY=starttls
