# =============================================================================
# ChildCheck project-specific ignores
# =============================================================================

# --- Runtime data (NEVER commit user data) ---
# SQLite database (single file at db/custom.db).
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm
# Keep the .gitkeep so the dir exists in git.
!db/.gitkeep

# User-uploaded photos (encrypted at rest, but still user data).
data/photos/
data/branding/
data/backups/
data/updates/
# Keep the data dir structure.
!data/.gitkeep

# Persisted runtime config (auto-generated NEXTAUTH_SECRET etc.).
config/

# --- Environment ---
.env
.env.local
.env.*.local

# --- Logs ---
dev.log
server.log
mini-services/realtime/realtime.log
*.log

# --- Build output ---
dist/
.next/standalone/

# --- Dev-only context files (stay in the PRIVATE dev repo, NOT the public repo) ---
# These files contain development session context from chat.z.ai and should
# not be in the public release repository. They ARE kept in the private dev
# repo (the .tar download from chat.z.ai includes them).
# worklog.md
# PLAN.md
# MORNING-SUMMARY.md
# agent-ctx/
# NOTE: These are commented out so they ARE committed to git. If you want
# them excluded from the PUBLIC repo, create a separate .gitignore in the
# public repo clone, OR use a separate clone with a different .gitignore.
# The recommended approach: push the same code to both repos — these files
# are development documentation and are fine to be public (they show the
# build history). If you prefer them private, uncomment the lines above in
# your public repo's .gitignore.

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
